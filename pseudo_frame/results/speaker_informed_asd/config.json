{
  "method": "Speaker-embedding-informed AV (simplified Clarke et al. 2025)",
  "audio_speaker_source": "babar_ecapa_enrollment_runs/enroll_<split>_predictions.csv (clip-level ECAPA cosine to target prototype)",
  "audio_pseudo_source": "pseudo_frame/results/wavlm_pseudo_frame/<split>_predictions.csv",
  "visual_features": [
    "face_count_max",
    "face_count_mean",
    "face_area_max_norm",
    "face_area_mean_norm",
    "face_confidence_mean",
    "face_track_coverage_ratio",
    "n_distinct_tracks",
    "has_any_face",
    "eligibility_score",
    "face_intensity_std_mean",
    "face_intensity_std_std",
    "face_intensity_std_max",
    "face_intensity_std_p95",
    "mouth_intensity_std_mean",
    "mouth_intensity_std_std",
    "mouth_intensity_std_max",
    "mouth_intensity_std_p95",
    "face_motion_energy_mean",
    "face_motion_energy_std",
    "face_motion_energy_max",
    "face_motion_energy_p95",
    "mouth_region_motion_energy_mean",
    "mouth_region_motion_energy_std",
    "mouth_region_motion_energy_max",
    "mouth_region_motion_energy_p95",
    "n_mouth_frames",
    "track_n_frames",
    "mouth_extraction_rate",
    "mouth_motion_variance",
    "face_motion_log_max"
  ],
  "fusion": "joint = speaker \u00d7 visual; final = \u03b1\u00b7pseudo + (1\u2212\u03b1)\u00b7joint",
  "alpha": 0.1,
  "threshold_fused": 0.08499999999999999,
  "seed": 42,
  "created": "2026-04-29",
  "note": "Per-face-track ECAPA-vs-prototype is not available in this project's enrollment cache; we use clip-level ECAPA (BabAR enrollment prob) as the speaker score. The multiplicative joint enforces both-modality agreement, which is the Clarke design's discriminative gain on multi-speaker clips."
}